title: "ayg: Indexed code search using sparse n-gram inverted indexes"
authors:
  - family-names: "Yousri"
    given-names: "Ahmed"
    alias: "hemeda3"
    orcid: ""
version: 0.1.0
date-released: 2024-03-24
